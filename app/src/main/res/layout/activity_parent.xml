<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF9F6"
    tools:context=".ParentActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- HEADER -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/parent_monitor_title"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#444444"/>
                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/system_initializing"
                    android:textSize="14sp"
                    android:textStyle="italic"
                    android:textColor="#888888"/>
            </LinearLayout>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/headerLayout"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:paddingBottom="120dp">

                <!-- PAIRING SCREEN -->
                <LinearLayout
                    android:id="@+id/pairingLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="24dp">

                        <Button
                            android:id="@+id/btnMethodLan"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:text="@string/method_lan"
                            android:backgroundTint="#A9CFFF"
                            android:textColor="#FFFFFF"
                            android:layout_marginEnd="8dp"
                            android:textStyle="bold"/>

                        <Button
                            android:id="@+id/btnMethodDirect"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:text="@string/method_direct"
                            android:backgroundTint="#EEEEEE"
                            android:textColor="#888888"
                            android:layout_marginStart="8dp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutLanPairing"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/qr_instruction"
                            android:textColor="#666666"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textAlignment="center"
                            android:layout_marginBottom="16dp"/>

                        <soup.neumorphism.NeumorphCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:neumorph_shapeType="pressed"
                            app:neumorph_backgroundColor="#FAF9F6">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="20dp">
                                <ImageView
                                    android:id="@+id/ivQrCode"
                                    android:layout_width="match_parent"
                                    android:layout_height="280dp"
                                    android:scaleType="fitCenter"
                                    android:contentDescription="@string/desc_qr_code"/>
                            </LinearLayout>
                        </soup.neumorphism.NeumorphCardView>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/wifi_sync_requirement"
                            android:textColor="#FF5252"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textAlignment="center"
                            android:layout_marginTop="24dp"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="16dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutDirectPairing"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/searching_baby_unit"
                            android:textColor="#666666"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:textAlignment="center"
                            android:layout_marginBottom="16dp"/>

                        <ProgressBar
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:layout_marginBottom="16dp"/>

                        <LinearLayout
                            android:id="@+id/llPeerList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- DASHBOARD -->
                <LinearLayout
                    android:id="@+id/dashboardLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <soup.neumorphism.NeumorphCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:neumorph_backgroundColor="#A9CFFF"
                        app:neumorph_shapeType="flat">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">
                            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/live_insights" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" android:textAlignment="center" android:layout_marginBottom="20dp"/>

                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="24dp">
                                <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" app:cardCornerRadius="20dp" app:cardBackgroundColor="#FFFFFF" android:layout_marginEnd="10dp" app:cardElevation="0dp">
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp" android:gravity="center">
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/insight_emotion" android:textColor="#888888" android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.1"/>
                                        <TextView android:id="@+id/tvInsightMood" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/mood_calm" android:textColor="#333333" android:textSize="18sp" android:textStyle="bold"/>
                                    </LinearLayout>
                                </androidx.cardview.widget.CardView>
                                <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" app:cardCornerRadius="20dp" app:cardBackgroundColor="#FFFFFF" android:layout_marginStart="10dp" app:cardElevation="0dp">
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp" android:gravity="center">
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/insight_posture" android:textColor="#888888" android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.1"/>
                                        <TextView android:id="@+id/tvInsightPosture" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/posture_safe" android:textColor="#333333" android:textSize="18sp" android:textStyle="bold"/>
                                    </LinearLayout>
                                </androidx.cardview.widget.CardView>
                            </LinearLayout>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Real-time Motion Intensity"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:layout_marginBottom="8dp"
                                android:layout_marginStart="4dp"/>
                            <SeekBar
                                android:id="@+id/sliderMogMeter"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:progressTint="#FFFFFF"
                                android:thumbTint="@android:color/transparent"
                                android:max="10000"
                                android:progress="0"
                                android:enabled="false"/>
                        </LinearLayout>
                    </soup.neumorphism.NeumorphCardView>

                    <soup.neumorphism.NeumorphCardView
                        android:id="@+id/btnNeumorphStream"
                        android:layout_width="match_parent"
                        android:layout_height="110dp"
                        app:neumorph_backgroundColor="#FAF9F6"
                        app:neumorph_shapeType="flat"
                        android:layout_marginTop="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvStreamBtnText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/view_live_stream"
                                android:textColor="#A37BFF"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"/>
                        </LinearLayout>
                    </soup.neumorphism.NeumorphCardView>

                    <LinearLayout
                        android:id="@+id/svHistoryContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="32dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/recent_activity"
                            android:textColor="#666666"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp"/>
                        <LinearLayout android:id="@+id/llAlertHistory" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- FLOATING ACTION BUTTON -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="24dp"
            app:srcCompat="@android:drawable/ic_menu_preferences"
            app:backgroundTint="#A37BFF"
            app:tint="#FFFFFF"
            android:contentDescription="@string/app_name"/>

        <!-- VIDEO POPUP OVERLAY -->
        <FrameLayout
            android:id="@+id/videoPopupOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#CC000000"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_margin="20dp"
                android:orientation="vertical"
                android:background="@drawable/pill_background"
                android:padding="12dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="Live Monitor Feed"
                        android:textStyle="bold"
                        android:textColor="#333333"/>
                    <ImageButton
                        android:id="@+id/btnCloseVideoPopup"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="#888888"
                        android:contentDescription="@string/desc_close_monitor"/>
                </RelativeLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:layout_constraintDimensionRatio="9:16"
                    android:layout_weight="1"
                    android:minHeight="400dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="match_parent">
                        <SurfaceView
                            android:id="@+id/svLiveVideo"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />

                        <!-- Floating Controls on Video -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:layout_centerHorizontal="true"
                            android:layout_marginBottom="16dp"
                            android:orientation="horizontal"
                            android:padding="8dp"
                            android:background="#88000000"
                            android:backgroundTint="#88000000">

                            <ImageButton
                                android:id="@+id/btnOverlaySwitch"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@android:drawable/ic_menu_camera"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                app:tint="#FFFFFF"
                                android:layout_marginEnd="16dp"/>

                            <ImageButton
                                android:id="@+id/btnOverlayRotate"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:src="@android:drawable/ic_menu_rotate"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                app:tint="#FFFFFF"/>
                        </LinearLayout>
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </FrameLayout>

    </RelativeLayout>

    <!-- NAVIGATION DRAWER (Settings) -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FFFFFF">

        <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="System Config"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="24dp"/>

                <!-- Motion Sensitivity Setting -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Motion Threshold (Sensitivity)" android:textSize="14sp" android:textColor="#666666"/>
                <SeekBar
                    android:id="@+id/sliderMotionThreshold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="10000"
                    android:progress="3000"
                    android:layout_marginBottom="24dp"/>

                <!-- Alert Configuration -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Safety Escalation" android:textSize="14sp" android:textColor="#666666" android:layout_marginBottom="8dp"/>
                <CheckBox
                    android:id="@+id/cbAlarmCrying"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Alarm on Crying"
                    android:checked="true"/>
                <CheckBox
                    android:id="@+id/cbAlarmProne"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Alarm on Prone Position"
                    android:checked="true"
                    android:layout_marginBottom="24dp"/>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginBottom="24dp"/>

                <Button
                    android:id="@+id/btnReconnect"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Pair New Device"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:backgroundTint="#F5F5F5"
                    android:textColor="#333333"
                    android:textAllCaps="false"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnClearLog"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Purge Data Logs"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:backgroundTint="#FFF0F0"
                    android:textColor="#FF5252"
                    android:textAllCaps="false"/>

            </LinearLayout>
        </ScrollView>
    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>