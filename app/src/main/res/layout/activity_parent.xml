<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F0">

    <!-- MAIN CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- LOWERED HEADER -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="24dp"
            android:layout_marginTop="32dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Parent Unit"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#4A4A4A"/>
                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connected Securely"
                    android:textSize="14sp"
                    android:textColor="#888888"/>

                <LinearLayout
                    android:id="@+id/llBabyBattery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Baby Battery: "
                        android:textSize="12sp"
                        android:textColor="#AAAAAA"/>
                    <ProgressBar
                        android:id="@+id/pbBabyBattery"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="40dp"
                        android:layout_height="8dp"
                        android:progress="50"
                        android:progressTint="#4CAF50"
                        android:progressBackgroundTint="#DDDDDD"/>
                    <TextView
                        android:id="@+id/tvBabyBatteryPct"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" 50%"
                        android:textSize="10sp"
                        android:textColor="#AAAAAA"/>
                </LinearLayout>
            </LinearLayout>

            <!-- BACK BUTTON WITH NO SHADOW -->
            <ImageButton
                android:id="@+id/btnMainBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/pill_background"
                android:backgroundTint="#F2F2F2"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="#4A4A4A"
                android:elevation="0dp"
                app:elevation="0dp"/>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- PAIRING SECTION -->
                <LinearLayout
                    android:id="@+id/pairingLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <soup.neumorphism.NeumorphCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:neumorph_shapeType="pressed">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="24dp">
                            <ImageView
                                android:id="@+id/ivQrCode"
                                android:layout_width="250dp"
                                android:layout_height="250dp"
                                android:scaleType="fitCenter"
                                android:layout_marginBottom="16dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Scan to Pair Baby Unit"
                                android:textColor="#4A4A4A"
                                android:textStyle="bold"
                                android:textSize="18sp"/>
                        </LinearLayout>
                    </soup.neumorphism.NeumorphCardView>

                    <!-- WIFI WARNING AND NOTE -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="⚠️ Ensure both devices are connected to the same WiFi network."
                        android:textColor="#FF5252"
                        android:textSize="12sp"
                        android:textAlignment="center"
                        android:layout_marginTop="12dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="(Note: QR code will only be displayed when device is connected to WiFi)"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:textAlignment="center"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"/>
                </LinearLayout>

                <!-- DASHBOARD / LIVE INSIGHTS -->
                <LinearLayout
                    android:id="@+id/dashboardLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#b4d7ff"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        android:layout_marginBottom="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">
                            <!-- Header row: title + master alert quick toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Live Insights"
                            android:textColor="#4A4A4A"
                            android:textSize="22sp"
                            android:textStyle="bold"/>

                        <!-- Master alert quick-toggle (prominent, right of title) -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ALERTS"
                                android:textColor="#4A4A4A"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:layout_gravity="center"/>
                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/switchMasterAlertQuick"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true"/>
                        </LinearLayout>
                    </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="24dp">

                                <soup.neumorphism.NeumorphCardView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    app:neumorph_shapeType="pressed">
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp" android:gravity="center">
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mood" android:textColor="#888888" android:textSize="12sp"/>
                                        <TextView android:id="@+id/tvInsightMood" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Calm" android:textColor="#4CAF50" android:textSize="18sp" android:textStyle="bold"/>
                                    </LinearLayout>
                                </soup.neumorphism.NeumorphCardView>

                                <soup.neumorphism.NeumorphCardView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    app:neumorph_shapeType="pressed">
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp" android:gravity="center">
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Posture" android:textColor="#888888" android:textSize="12sp"/>
                                        <TextView android:id="@+id/tvInsightPosture" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Safe" android:textColor="#2196F3" android:textSize="18sp" android:textStyle="bold"/>
                                    </LinearLayout>
                                </soup.neumorphism.NeumorphCardView>
                            </LinearLayout>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Motion Meter"
                                android:textColor="#888888"
                                android:textStyle="bold"
                                android:layout_marginBottom="8dp"/>

                            <!-- MOTION METER AS SEEKBAR WITH DISTINCT THUMB -->
                            <SeekBar
                                android:id="@+id/motionMeter"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:progress="0"
                                android:progressTint="#FF9800"
                                android:thumbTint="#6200EE"
                                android:enabled="false"
                                android:splitTrack="false"
                                android:layout_marginBottom="16dp"/>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Sound Meter"
                                android:textColor="#888888"
                                android:textStyle="bold"
                                android:layout_marginBottom="8dp"/>

                            <SeekBar
                                android:id="@+id/soundMeter"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:progress="0"
                                android:progressTint="#2196F3"
                                android:thumbTint="#E91E63"
                                android:enabled="false"
                                android:splitTrack="false"
                                android:layout_marginBottom="16dp"/>

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- AI DISCLAIMER -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="AI is not perfect and can make mistakes. Do not rely solely on this monitor."
                        android:textColor="#AAAAAA"
                        android:textSize="11sp"
                        android:textStyle="italic"
                        android:textAlignment="center"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="16dp"/>

                    <!-- ALWAYS VISIBLE EVENT LOG -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Event Log"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#4A4A4A"
                        android:layout_marginBottom="12dp"
                        android:layout_marginStart="8dp"/>

                    <LinearLayout
                        android:id="@+id/llAlertHistory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvEmptyLog"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No events recorded yet."
                            android:textAlignment="center"
                            android:layout_marginTop="32dp"
                            android:textColor="#AAAAAA"
                            android:visibility="gone"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- FLOATING ACTION BUTTONS -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="78dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp"
            android:orientation="horizontal">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabVideo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:src="@android:drawable/presence_video_online"
                app:backgroundTint="#FFFFFF"
                app:elevation="8dp"
                app:tint="#f00090" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabMic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:src="@android:drawable/ic_btn_speak_now"
                app:backgroundTint="#FFFFFF"
                app:elevation="8dp"
                app:tint="#888888" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:src="@android:drawable/ic_menu_preferences"
                app:backgroundTint="#FFFFFF"
                app:elevation="8dp"
                app:tint="#4A4Ad3" />
        </LinearLayout>
    </LinearLayout>

    <!-- SLIDING CARD: VIDEO STREAM (Top-Down, 9:16) -->
    <soup.neumorphism.NeumorphCardView
        android:id="@+id/cardVideo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:neumorph_backgroundColor="#FFF8F0"
        app:neumorph_shapeType="flat">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/videoContainer"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:layout_constraintDimensionRatio="H,9:16"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#000000">
                    <SurfaceView
                        android:id="@+id/svLiveVideo"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <ImageButton
                android:id="@+id/btnCloseVideo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="16dp"
                android:background="@drawable/pill_background"
                android:backgroundTint="#80000000"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#FFFFFF"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- VIDEO ACTIONS -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_margin="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <ImageButton
                    android:id="@+id/btnCapture"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/pill_background"
                    android:backgroundTint="#80000000"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="#FFFFFF"/>

                <ImageButton
                    android:id="@+id/btnRecord"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/pill_background"
                    android:backgroundTint="#80000000"
                    android:src="@drawable/record_dot"
                    android:padding="12dp"
                    android:scaleType="fitCenter"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </soup.neumorphism.NeumorphCardView>

    <!-- SLIDING CARD: SETTINGS (Right-to-Center, Floating) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSettings"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="#b4d7ff"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@drawable/blue_border_background">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Settings"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#4A4A4A"/>

                <!-- BACK BUTTON FOR SETTINGS WITH NO SHADOW -->
                <ImageButton
                    android:id="@+id/btnCloseSettings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/pill_background"
                    android:backgroundTint="#F2F2F2"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="#4A4A4A"
                    android:elevation="0dp"
                    app:elevation="0dp"/>
            </RelativeLayout>

            <Button
                android:id="@+id/btnClearLog"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Clear Event Log"
                android:textAllCaps="false"
                android:backgroundTint="#FF5252"
                android:textColor="#FFFFFF"
                android:elevation="4dp"
                android:layout_marginBottom="24dp"/>

            <!-- ALERT TOGGLES -->
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchMasterAlert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Master Alert (All Alarms)"
                android:textColor="#4A4A4A"
                android:checked="true"
                android:layout_marginBottom="12dp"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchMediumAlert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Medium Alerts (Fussy/Motion)"
                android:textColor="#4A4A4A"
                android:checked="true"
                android:layout_marginBottom="12dp"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchLowAlert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Low Alerts (Mood/Sleep)"
                android:textColor="#4A4A4A"
                android:checked="true"
                android:layout_marginBottom="20dp"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginBottom="16dp"/>

            <!-- Quiet Hours section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quiet Hours"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#4A4A4A"
                android:layout_marginBottom="8dp"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchQuietHours"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Suppress medium alerts"
                android:textColor="#4A4A4A"
                android:layout_marginBottom="10dp"/>

            <!-- Start / End time row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="From"
                    android:textColor="#888888"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvQuietStart"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="22:00"
                    android:textColor="#2196F3"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingStart="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="To"
                    android:textColor="#888888"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvQuietEnd"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="07:00"
                    android:textColor="#2196F3"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingStart="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"/>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginBottom="16dp"/>

            <!-- Audio alert sensitivity -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sound Alert Sensitivity"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#4A4A4A"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvAudioSensLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Alert when: ≥ 40%"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <SeekBar
                android:id="@+id/seekAudioSens"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="40"
                android:progressTint="#2196F3"
                android:thumbTint="#E91E63"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="App Version 1.0.5\nBabyGuard Smart Monitor"
                android:textAlignment="center"
                android:textColor="#AAAAAA"
                android:textSize="12sp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- HIGH ALERT OVERLAY (RED BLINKING) -->
    <FrameLayout
        android:id="@+id/alertOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E53935"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAlertTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚨 CRITICAL ALERT"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvAlertMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTION REQUIRED"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:layout_marginBottom="48dp"/>

            <Button
                android:id="@+id/btnDismissAlert"
                android:layout_width="200dp"
                android:layout_height="70dp"
                android:text="DISMISS"
                android:backgroundTint="#FFFFFF"
                android:textColor="#E53935"
                android:textStyle="bold"
                android:textSize="18sp"
                app:cornerRadius="35dp"/>
        </LinearLayout>
    </FrameLayout>

</FrameLayout>