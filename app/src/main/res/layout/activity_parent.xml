<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8F0">

    <!-- MAIN CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- LOWERED HEADER -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="24dp"
            android:layout_marginTop="32dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Parent Unit"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#4A4A4A"/>
                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connected Securely"
                    android:textSize="14sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <!-- BACK BUTTON WITH NO SHADOW -->
            <ImageButton
                android:id="@+id/btnMainBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/pill_background"
                android:backgroundTint="#F2F2F2"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="#4A4A4A"
                android:elevation="0dp"
                app:elevation="0dp"/>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- PAIRING SECTION -->
                <soup.neumorphism.NeumorphCardView
                    android:id="@+id/pairingLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:neumorph_shapeType="pressed"
                    android:visibility="visible">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="24dp">
                        <ImageView
                            android:id="@+id/ivQrCode"
                            android:layout_width="250dp"
                            android:layout_height="250dp"
                            android:scaleType="fitCenter"
                            android:layout_marginBottom="16dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scan to Pair Baby Unit"
                            android:textColor="#4A4A4A"
                            android:textStyle="bold"
                            android:textSize="18sp"/>
                        <!-- WIFI WARNING -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚠️ Ensure both devices are connected to the same WiFi network."
                            android:textColor="#FF5252"
                            android:textSize="12sp"
                            android:textAlignment="center"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </soup.neumorphism.NeumorphCardView>

                <!-- DASHBOARD / LIVE INSIGHTS -->
                <LinearLayout
                    android:id="@+id/dashboardLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#b4d7ff"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        android:layout_marginBottom="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Live Insights"
                                android:textColor="#4A4A4A"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="24dp"/>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="24dp">

                                <soup.neumorphism.NeumorphCardView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    app:neumorph_shapeType="pressed">
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp" android:gravity="center">
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mood" android:textColor="#888888" android:textSize="12sp"/>
                                        <TextView android:id="@+id/tvInsightMood" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Calm" android:textColor="#4CAF50" android:textSize="18sp" android:textStyle="bold"/>
                                    </LinearLayout>
                                </soup.neumorphism.NeumorphCardView>

                                <soup.neumorphism.NeumorphCardView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    app:neumorph_shapeType="pressed">
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp" android:gravity="center">
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Posture" android:textColor="#888888" android:textSize="12sp"/>
                                        <TextView android:id="@+id/tvInsightPosture" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Safe" android:textColor="#2196F3" android:textSize="18sp" android:textStyle="bold"/>
                                    </LinearLayout>
                                </soup.neumorphism.NeumorphCardView>
                            </LinearLayout>

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Motion Meter"
                                android:textColor="#888888"
                                android:textStyle="bold"
                                android:layout_marginBottom="8dp"/>

                            <!-- MOTION METER AS SEEKBAR WITH DISTINCT THUMB -->
                            <SeekBar
                                android:id="@+id/motionMeter"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:progress="30"
                                android:progressTint="#FF9800"
                                android:thumbTint="#6200EE"
                                android:enabled="false"
                                android:splitTrack="false"
                                android:layout_marginBottom="16dp"/>

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- AI DISCLAIMER -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="AI is not perfect and can make mistakes. Do not rely solely on this monitor."
                        android:textColor="#AAAAAA"
                        android:textSize="11sp"
                        android:textStyle="italic"
                        android:textAlignment="center"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="16dp"/>

                    <!-- ALWAYS VISIBLE EVENT LOG -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Event Log"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#4A4A4A"
                        android:layout_marginBottom="12dp"
                        android:layout_marginStart="8dp"/>

                    <LinearLayout
                        android:id="@+id/llAlertHistory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/tvEmptyLog"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No events recorded yet."
                            android:textAlignment="center"
                            android:layout_marginTop="32dp"
                            android:textColor="#AAAAAA"
                            android:visibility="gone"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <!-- FLOATING ACTION BUTTONS -->
        <LinearLayout
            android:layout_width="147dp"
            android:layout_height="86dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="32dp"
            android:orientation="horizontal">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabVideo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:src="@android:drawable/presence_video_online"
                app:backgroundTint="#FFFFFF"
                app:elevation="8dp"
                app:tint="#f00090" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:src="@android:drawable/ic_menu_preferences"
                app:backgroundTint="#FFFFFF"
                app:elevation="8dp"
                app:tint="#4A4Ad3" />
        </LinearLayout>
    </LinearLayout>

    <!-- SLIDING CARD: VIDEO STREAM (Top-Down, 9:16) -->
    <soup.neumorphism.NeumorphCardView
        android:id="@+id/cardVideo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:neumorph_backgroundColor="#FFF8F0"
        app:neumorph_shapeType="flat">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="4dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/videoContainer"
                android:layout_width="0dp"
                android:layout_height="0dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:layout_constraintDimensionRatio="H,9:16"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#000000">
                    <SurfaceView
                        android:id="@+id/svLiveVideo"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <ImageButton
                android:id="@+id/btnCloseVideo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="16dp"
                android:background="@drawable/pill_background"
                android:backgroundTint="#80000000"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#FFFFFF"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </soup.neumorphism.NeumorphCardView>

    <!-- SLIDING CARD: SETTINGS (Right-to-Center, Floating) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSettings"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical|end"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="#b4d7ff"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@drawable/blue_border_background">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Settings"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#4A4A4A"/>

                <!-- BACK BUTTON FOR SETTINGS WITH NO SHADOW -->
                <ImageButton
                    android:id="@+id/btnCloseSettings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/pill_background"
                    android:backgroundTint="#F2F2F2"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="#4A4A4A"
                    android:elevation="0dp"
                    app:elevation="0dp"/>
            </RelativeLayout>

            <Button
                android:id="@+id/btnClearLog"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Clear Event Log"
                android:textAllCaps="false"
                android:backgroundTint="#FF5252"
                android:textColor="#FFFFFF"
                android:elevation="4dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="App Version 1.0.5\nBabyGuard Smart Monitor"
                android:textAlignment="center"
                android:textColor="#AAAAAA"
                android:textSize="12sp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>